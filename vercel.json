{
  "buildCommand": "npx prisma generate && next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/morning-notification",
      "schedule": "30 10 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-insights",
      "schedule": "0 18 * * 5"
    },
    {
      "path": "/api/cron/daily-insights",
      "schedule": "0 17 * * 1-5"
    }
  ]
}
