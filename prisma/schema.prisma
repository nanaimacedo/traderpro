generator client {
  provider        = "prisma-client-js"
  output = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trade {
  id              String   @id @default(cuid())
  date            DateTime
  time            String // horario da operacao HH:mm
  asset           String   @default("WIN")
  direction       String // COMPRA | VENDA
  entryPrice      Float
  exitPrice       Float
  contracts       Int
  result          String // GAIN | LOSS | ZERO
  points          Float // pontos ganhos/perdidos
  financialResult Float // resultado em R$ (pontos * 0.20 * contratos)
  durationMinutes Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  diaryEntry   DiaryEntry? @relation(fields: [diaryEntryId], references: [id])
  diaryEntryId String?

  @@index([date])
  @@index([result])
}

model DiaryEntry {
  id        String   @id @default(cuid())
  date      DateTime
  title     String
  content   String // texto do diario
  mood      String? // OTIMISTA | NEUTRO | FRUSTRADO | DISCIPLINADO | ANSIOSO
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades Trade[]
  images DiaryImage[]

  @@index([date])
}

model DiaryImage {
  id           String     @id @default(cuid())
  filename     String
  originalName String
  path         String
  createdAt    DateTime   @default(now())

  diaryEntry   DiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)
  diaryEntryId String
}

model BrokerReport {
  id           String   @id @default(cuid())
  date         DateTime
  filename     String
  originalName String
  totalTrades  Int?
  totalGain    Float?
  totalLoss    Float?
  netResult    Float?
  fees         Float? // taxas e emolumentos
  rawData      String? // dados brutos extraidos do PDF
  createdAt    DateTime @default(now())
}

model MentorConversation {
  id        String           @id @default(cuid())
  title     String
  summary   String? // AI-generated summary of the conversation (for memory)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  MentorMessage[]
}

model TraderProfile {
  id             String   @id @default(cuid())
  name           String
  nickname       String? // como o mentor chama (ex: "guerreiro")
  asset          String   @default("WIN") // WIN, WDO, etc
  pointValue     Float    @default(0.20) // valor do ponto por contrato
  currentJob     String? // cargo atual
  monthlyGoal    Float    @default(4400) // meta mensal R$
  maxEntries     Int      @default(4) // limite de entradas por dia
  methodology    String   @default("oliver-velez") // plugin de metodologia
  philosophy     String? // ex: "Cristã / Estoicismo / PNL / Flow"
  motivation     String? // por que faz trade (família, liberdade, etc)
  mentoringSince DateTime @default(now())
  onboarded      Boolean  @default(false) // se já completou onboarding
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MentorMessage {
  id             String             @id @default(cuid())
  role           String // user | assistant
  content        String
  createdAt      DateTime           @default(now())
  conversation   MentorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
}

model Replay {
  id        String   @id @default(cuid())
  date      DateTime
  title     String
  content   String // diário do replay
  mood      String? // OTIMISTA | NEUTRO | FRUSTRADO | DISCIPLINADO | ANSIOSO
  entries   Int      @default(0) // quantidade de entradas
  gains     Int      @default(0)
  losses    Int      @default(0)
  zeros     Int      @default(0)
  points    Float    @default(0) // pontos totais
  result    Float    @default(0) // resultado financeiro R$
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String // chave publica do cliente
  auth      String // token de autenticacao
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id        String   @id @default(cuid())
  title     String
  body      String
  sentAt    DateTime @default(now())
  success   Int      @default(0)
  failed    Int      @default(0)
}
