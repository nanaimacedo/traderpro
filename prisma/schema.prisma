generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash
  plan      String   @default("free") // free | pro
  role      String   @default("trader") // trader | owner
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades        Trade[]
  diaryEntries  DiaryEntry[]
  brokerReports BrokerReport[]
  conversations MentorConversation[]
  profile       TraderProfile?
  replays       Replay[]
  subscriptions PushSubscription[]
  subscription  Subscription?
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  plan             String    @default("free") // free | pro
  status           String    @default("active") // active | canceled | past_due | trialing
  trialEnd         DateTime?
  currentPeriodEnd DateTime?
  cancelAtEnd      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Trade {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  time            String // horario da operacao HH:mm
  asset           String   @default("WIN") // WIN | WDO | PETR4 | VALE3 | BTC...
  direction       String // COMPRA | VENDA
  entryPrice      Float
  exitPrice       Float
  contracts       Int
  result          String // GAIN | LOSS | ZERO
  points          Float // pontos ganhos/perdidos
  financialResult Float // resultado em R$
  pointValue      Float    @default(0.20) // valor do ponto no momento do trade
  durationMinutes Int?
  setup           String? // tag do setup usado: EB, BT, TT, RBI, GBI, OB, FVG, etc
  source          String   @default("manual") // manual | csv-profit | csv-tryd | csv-metatrader
  notes           String?
  screenshotUrl   String? // URL da screenshot anotada
  emotions        String? // emoções sentidas (JSON array: ["ANSIEDADE","MEDO",...])
  whatWentRight   String? // o que fiz certo
  whereToImprove  String? // onde posso melhorar
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  diaryEntry   DiaryEntry? @relation(fields: [diaryEntryId], references: [id])
  diaryEntryId String?

  @@index([userId, date])
  @@index([userId, result])
  @@index([setup])
}

model DiaryEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  title     String
  content   String // texto do diario
  mood      String? // OTIMISTA | NEUTRO | FRUSTRADO | DISCIPLINADO | ANSIOSO
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades Trade[]
  images DiaryImage[]

  @@index([userId, date])
}

model DiaryImage {
  id           String     @id @default(cuid())
  filename     String
  originalName String
  path         String
  createdAt    DateTime   @default(now())

  diaryEntry   DiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)
  diaryEntryId String
}

model BrokerReport {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime
  filename     String
  originalName String
  totalTrades  Int?
  totalGain    Float?
  totalLoss    Float?
  netResult    Float?
  fees         Float? // taxas e emolumentos
  rawData      String? // dados brutos extraidos do PDF
  // Estatísticas detalhadas do resumo da corretora
  gains              Int?
  losses             Int?
  zeros              Int?
  tradingDays        Int?
  maxDailyGain       Float?
  maxDailyLoss       Float?
  maxGainPerOp       Float?
  maxLossPerOp       Float?
  maxDurationMinutes Int?
  maxDurationResult  Float?
  minDurationMinutes Int?
  minDurationResult  Float?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model MentorConversation {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  summary   String? // AI-generated summary for memory
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  MentorMessage[]

  @@index([userId])
}

model TraderProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  nickname       String? // como o mentor chama (ex: "guerreiro")
  asset          String   @default("WIN") // WIN, WDO, etc
  pointValue     Float    @default(0.20) // valor do ponto por contrato
  currentJob     String? // cargo atual
  monthlyGoal    Float    @default(4400) // meta mensal R$
  maxEntries     Int      @default(4) // limite de entradas por dia
  dailyLossLimit Float? // loss diario maximo antes de circuit breaker (R$)
  methodology    String   @default("oliver-velez") // plugin de metodologia
  philosophy     String? // ex: "Crista / Estoicismo / PNL / Flow"
  motivation     String? // por que faz trade (familia, liberdade, etc)
  mentoringSince DateTime @default(now())
  onboarded      Boolean  @default(false) // se ja completou onboarding
  mentorRules    String?  // JSON: [{rule: string, date: string}] — preferencias/correcoes aprendidas
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MentorMessage {
  id             String             @id @default(cuid())
  role           String // user | assistant
  content        String
  createdAt      DateTime           @default(now())
  conversation   MentorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
}

model Replay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  title     String
  content   String // diario do replay
  mood      String? // OTIMISTA | NEUTRO | FRUSTRADO | DISCIPLINADO | ANSIOSO
  entries   Int      @default(0)
  gains     Int      @default(0)
  losses    Int      @default(0)
  zeros     Int      @default(0)
  points    Float    @default(0)
  result    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images ReplayImage[]

  @@index([userId, date])
}

model ReplayImage {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  path         String
  createdAt    DateTime @default(now())

  replay   Replay @relation(fields: [replayId], references: [id], onDelete: Cascade)
  replayId String
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String // chave publica do cliente
  auth      String // token de autenticacao
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model NotificationLog {
  id        String   @id @default(cuid())
  title     String
  body      String
  sentAt    DateTime @default(now())
  success   Int      @default(0)
  failed    Int      @default(0)
}

model EconomicEvent {
  id        String   @id @default(cuid())
  date      DateTime
  time      String? // HH:mm UTC
  title     String
  country   String // BR | US | EU
  impact    String // LOW | MEDIUM | HIGH
  actual    String?
  forecast  String?
  previous  String?
  createdAt DateTime @default(now())

  @@index([date])
}
